#!/usr/bin/env php
<?php

// Find autoload.php in both local dev and global install contexts
$autoloadPaths = [
    __DIR__ . '/../vendor/autoload.php',      // Local dev: bin/../vendor/autoload.php
    __DIR__ . '/../../../autoload.php',   // Global install: vendor/didon-code/open-microservice/bin/../../vendor/autoload.php
];

$autoloadFound = false;
foreach ($autoloadPaths as $path) {
    if (file_exists($path)) {
        require $path;
        $autoloadFound = true;
        break;
    }
}

if (!$autoloadFound) {
    fwrite(STDERR, "Composer autoload.php not found\n");
    exit(1);
}

use OpenMicroservice\AddServiceCommand;
use OpenMicroservice\InitCommand;
use OpenMicroservice\NewProjectCommand;
use Symfony\Component\Console\Application;

$application = new Application('Open Microservice CLI', '0.1.0');

$application->add(new NewProjectCommand());
$application->add(new InitCommand());
$application->add(new AddServiceCommand());

$application->run();